[Unit]
Description=StockTipsBot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Change User and WorkingDirectory to match your Pi setup
User=pi
WorkingDirectory=/home/pi/StockTipsBot
ExecStart=/home/pi/StockTipsBot/venv/bin/python main.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
