[Unit]
Description=StockTipsBot — SUPER Screener ($2–$50 paper, WebSocket)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=defectuous
WorkingDirectory=/home/defectuous/StockTipsBot
ExecStart=/home/defectuous/StockTipsBot/.venv/bin/python run_super_screener.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
