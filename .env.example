# ── Alpaca API ────────────────────────────────────────────────────────────────
# Paper trading keys: https://app.alpaca.markets  →  Paper  →  API Keys
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_API_SECRET=your_paper_api_secret_here
ALPACA_PAPER=true

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# ── Trading Config ────────────────────────────────────────────────────────────
BUY_AMOUNT_USD=100
TRAILING_STOP_PERCENT=25

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Generated from Google Cloud Console (see GMAIL_SETUP.md)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# ── Bot Timing ────────────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL=60
EMAIL_MAX_AGE_SECONDS=120
TICKER_COOLDOWN_MINUTES=30
