# ── Alpaca API ────────────────────────────────────────────────────────────────
# Paper trading keys: https://app.alpaca.markets  →  Paper  →  API Keys
ALPACA_PAPER=true

SML_ALPACA_API_KEY=your_sml_paper_api_key_here
SML_ALPACA_API_SECRET=your_sml_paper_api_secret_here

MID_ALPACA_API_KEY=your_mid_paper_api_key_here
MID_ALPACA_API_SECRET=your_mid_paper_api_secret_here

SUPER_ALPACA_API_KEY=your_super_paper_api_key_here
SUPER_ALPACA_API_SECRET=your_super_paper_api_secret_here

# ── Live account (run_live_screener.py) ───────────────────────────────────────
# Live account keys: https://app.alpaca.markets  →  Live  →  API Keys
LIVE_ALPACA_API_KEY=your_live_api_key_here
LIVE_ALPACA_API_SECRET=your_live_api_secret_here

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Spreadsheet ID from the URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
# Run setup_gmail.py once to generate token.json (see GMAIL_SETUP.md)
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# ── Shared Trading Config ─────────────────────────────────────────────────────
TRAILING_STOP_PERCENT=10
HARD_STOP_PCT=5
MAX_ENTRY_MOVE_PCT=8
# SML2_MAX_ENTRY_MOVE_PCT=15   # optional per-screener override, e.g. SML2
PROFIT_LOCK_PCT=15
TIGHT_STOP_PCT=5
RSI_EXIT_LEVEL=75
MAX_HOLD_MINUTES=90
BUY_COOLDOWN_SECONDS=86400
SCAN_INTERVAL_SECONDS=60
START_TIME_ET=09:30
STOP_BUY_TIME_ET=11:45
DUMP_TIME_ET=12:00

# ── SML Screener ($0.50–$5.00) — run_sml_screener.py ─────────────────────────
MAX_POSITIONS=2                # SML + MID both read this

# ── MID Screener ($2–$20) — run_mid_screener.py ──────────────────────────────
MID_MIN_PRICE=2.00
MID_MAX_PRICE=20.00

# ── SUPER Screener ($2–$50, WebSocket) — run_super_screener.py ───────────────
SUPER_MAX_POSITIONS=999        # effectively unlimited
SUPER_MIN_PRICE=2.00
SUPER_MAX_PRICE=50.00
SUPER_MAX_BUY_AMOUNT=500

# ── LIVE Screener ($0.50–$5.00, real money) — run_live_screener.py ───────────
LIVE_MAX_POSITIONS=2
LIVE_STARTING_BALANCE=500
